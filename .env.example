# VectorGallery API Configuration
# ================================
# Copy this file to .env and fill in your settings

# Project metadata
PROJECT_NAME=VectorGallery API
VERSION=1.0.0

# CORS: allowed origins (comma-separated or single value)
CORS_ORIGINS=*

# Embedding provider: "local" for offline CLIP or "openai" for cloud embeddings
EMBEDDING_PROVIDER=local

# Embedding model name
# For local: "clip-ViT-B-32", "clip-ViT-L-14", etc.
# For OpenAI: "text-embedding-3-small", "text-embedding-3-large", etc.
EMBEDDING_MODEL=clip-ViT-B-32

# Vector dimension (must match the model's output dimensionality)
# clip-ViT-B-32: 512
# clip-ViT-L-14: 768
# OpenAI text-embedding-3-small: 1536
# OpenAI text-embedding-3-large: 3072
VECTOR_DIMENSION=512

# OpenAI API Key (only used if EMBEDDING_PROVIDER=openai)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Data storage path (relative to container/app root)
DATA_PATH=./data.jsonl
